{
  "name": "awsprint",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "description": "AWS SAA 学習アプリ — 図解連動ハイライトで文章要件→構成図の変換力を鍛える（ランニングコスト0円構成）",
  "scripts": {
    "dev": "vite",
